# =====================================================================
# M5 Max Produções - Environment Variables
# =====================================================================
# Copie este arquivo para `.env` (local) e preencha com seus valores.
# Para Vercel/Produção, configure as mesmas variáveis no painel do projeto.
#
# ⚠️ NUNCA commite o arquivo `.env` real.
# =====================================================================

# --- Supabase principal (banco do projeto) -----------------------------
VITE_SUPABASE_URL=https://SEU-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...sua-anon-key-publica

# --- Supabase alternativo (fonte externa de leads) ---------------------
# Opcional. Se vazio, o painel admin lê apenas leads do banco principal.
# Aponta para um projeto Supabase separado (ex: landing page externa).
VITE_LEADS_SUPABASE_URL=
VITE_LEADS_SUPABASE_ANON_KEY=

# --- Identidade do site -----------------------------------------------
VITE_SITE_URL=https://m5max.com
VITE_SITE_NAME=M5 Max Produções
VITE_CONTACT_EMAIL=fogos@m5max.com
VITE_CONTACT_PHONE=+5561982735575
VITE_WHATSAPP_NUMBER=5561982735575

# --- Analytics & Marketing (todos opcionais) ---------------------------
# Google Tag Manager
VITE_GTM_ID=
# Google Analytics 4
VITE_GA4_ID=
# Google Ads
VITE_GADS_ID=
# Meta (Facebook) Pixel
VITE_META_PIXEL_ID=

# --- YouTube (para vitrine de vídeos) ---------------------------------
VITE_YOUTUBE_CHANNEL_ID=
VITE_YOUTUBE_API_KEY=

# --- Ambiente ---------------------------------------------------------
# development | production | staging
VITE_NODE_ENV=development
